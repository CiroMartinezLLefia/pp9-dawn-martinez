<section class="top3 page-width">
  {% if section.settings.title != blank %}
    <h2>{{ section.settings.title }}</h2>
  {% endif %}

  <div class="top3__grid">
    {% for block in section.blocks %}
      <div class="top3__item" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.heading }}
        {% endif %}

        {% if block.settings.heading != blank %}
          <h3>{{ block.settings.heading }}</h3>
        {% endif %}

        {% if block.settings.text != blank %}
          <p>{{ block.settings.text }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Top 3",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo de la sección",
      "default": "Top 3 futbolistas de la historia"
    }
  ],
  "blocks": [
    {
      "type": "info_block",
      "name": "Bloque de info",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titulo del bloque",
          "default": "Titulo bloque"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto del bloque",
          "default": "Este es el texto del bloque. Aquí puedes escribir una descripción o información adicional sobre el contenido del bloque."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen del bloque"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top 3",
      "blocks": [
        {
          "type": "info_block"
        },
        {
          "type": "info_block"
        },
        {
          "type": "info_block"
        }
      ]
    }
  ]
}
{% endschema %}